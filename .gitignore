# Simulation build output (generated by `make` / `run_tests.sh`)
sim/

# Stray waveform / log artifacts
*.vcd
*.vvp

# FPGA synthesis build artifacts (yosys/nextpnr-ice40/icepack outputs)
fpga/**/*.json
fpga/**/*.asc
fpga/**/*.bin
fpga/**/*.aig

# Quartus (DE1-SoC / Cyclone V) build output
fpga/de1soc/db/
fpga/de1soc/incremental_db/
fpga/de1soc/output_files/
fpga/de1soc/*.qws
fpga/de1soc/*.rpt
fpga/de1soc/*.rbf
fpga/de1soc/*.sof

# RP2350 firmware out-of-tree build dirs (build/ = UART bridge,
# build-spi/ = TPU_LINK_SPI=ON variant)
firmware/build*/

# Downloaded MNIST idx files (mnist/train_mnist.py fetches these; ~11MB, not tracked)
mnist/data/

# Python venv created directly in the project root (`python3 -m venv .`)
bin/
include/
lib/
pyvenv.cfg
__pycache__/

# Kept locally only, untracked from the repo
docs/FPGA.md
docs/sequencer_uart_design.md
