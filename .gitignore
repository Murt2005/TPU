# Simulation build output (generated by `make` / `run_tests.sh`)
sim/

# Stray waveform / log artifacts
*.vcd
*.vvp

# FPGA synthesis build artifacts (yosys/nextpnr-ice40/icepack outputs)
fpga/**/*.json
fpga/**/*.asc
fpga/**/*.bin

# Downloaded MNIST idx files (mnist/train_mnist.py fetches these; ~11MB, not tracked)
mnist/data/

# Python venv created directly in the project root (`python3 -m venv .`)
bin/
include/
lib/
pyvenv.cfg
__pycache__/

# Kept locally only, untracked from the repo
docs/FPGA.md
docs/sequencer_uart_design.md
