# Simulation build output (generated by `make` / `run_tests.sh`)
sim/

# Stray waveform / log artifacts
*.vcd
*.vvp

# FPGA synthesis build artifacts (yosys/nextpnr-ice40/icepack outputs)
fpga/**/*.json
